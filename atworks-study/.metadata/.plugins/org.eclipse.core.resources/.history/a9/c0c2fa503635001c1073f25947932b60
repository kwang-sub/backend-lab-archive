package com.spring.shop.gallery;


import javax.servlet.http.HttpServletRequest;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestMethod;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.multipart.MultipartFile;

@Controller
public class GalleryController {
	
	
	@Autowired
	GalleryDAO gDAO;
	
	@GetMapping("/gallery")
	public String gallery(HttpServletRequest req) {
		
		req.setAttribute("contentPage", "gallery/gallery.jsp");
		return "home";
	}
	
	@GetMapping("/gallery/write")
	public String writePage(HttpServletRequest req) {
		
		req.setAttribute("contentPage", "gallery/write.jsp");
		return "home";
	}
	
	
	@PostMapping("/gallery/write")
	public String write(HttpServletRequest req, @RequestParam("img") MultipartFile file) {
		
		gDAO.insertGallery(req,file);
		
		req.setAttribute("contentPage", "gallery/gallery.jsp");
		return "home";
	}
	
}
