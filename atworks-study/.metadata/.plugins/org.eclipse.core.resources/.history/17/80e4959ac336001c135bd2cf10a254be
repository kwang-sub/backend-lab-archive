<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>

	<div class="contaner">
		<div class="row">
			<div class="col-2"></div>
			<div class="col-8">
				<table class="table">
				  <thead>
				    <tr>
				      <th scope="col">국내 확진자수</th>
				      <th scope="col">국내 완치자수</th>
				      <th scope="col">국내 사망자수</th>
				      <th scope="col">국내 격리자수</th>
				    </tr>
				  </thead>
				  <tbody id="total">
				  
				   
				  </tbody>
				</table>
				
				<div >
					<canvas id="myChart" width="400px" height="400px"></canvas>
				</div>
			</div>
			<div class="col-2"></div>
			
		</div>
		
	</div>
	<div class="container"> 
		<canvas id="myChart"></canvas> 
	</div>
	
	<div class="container">
		<div>
			<select class="form-select" aria-label="Default select example">
			  <option selected>지역을 선택해주세요</option>
			  <option value="seouli">서울</option>
			  <option value="busan">부산</option>
			  <option value="gyeonggi">경기</option>
			  <option value="chungbuk">충북</option>
			</select>
		</div>
		<div>
			<table class="table">
				  <thead>
				    <tr>
				      <th scope="col">시도명</th>
				      <th scope="col">신규확진환자수</th>
				      <th scope="col">확진환자수</th>
				      <th scope="col">완치자수</th>
				      <th scope="col">사망자</th>
				    </tr>
				  </thead>
				  <tbody id="local-tbody">
				  
				   
				  </tbody>
				</table>		
		</div>
	</div>



<script type="text/javascript">
	
	
	$(".form-select").on("change", function () {
		$.ajax({
			url: "https://api.corona-19.kr/korea/country/new/?serviceKey=BedTft6H3gDEqN4Z18I7vAmJlcGXxjCki",
			type : 'get',
			success : function(value){
				var m = $(".form-select option:selected").val();
		/* 		console.log(m)
				console.log(value.m);
				console.log(value.busan); */
				console.log(value);
				
				$("#local-tbody").children().remove();
				
				var html = '';
				html += '<td>'+value[m].countryName+'</td>';
				html += '<td>'+value[m].newCase+'</td>';
				html += '<td>'+value[m].totalCase+'</td>';
				html += '<td>'+value[m].recovered+'</td>';
				html += '<td>'+value[m].death+'</td>';
				
				$("#local-tbody").append(html);
				
				
				
			}
		})
		
	})


	var initialize = function(){
		var Html = "";
		$.ajax({
			type : 'get',
			url : "https://api.corona-19.kr/korea/?serviceKey=BedTft6H3gDEqN4Z18I7vAmJlcGXxjCki",
			success : function(value) {
				
				console.log(value);
				
				var html = '';
				
				html += '<tr>';
				html += '<td>'+value.TotalCase;
				html += '</td>';
				html += '<td>'+value.TotalRecovered;
				html += '</td>';
				html += '<td>'+value.TotalDeath;
				html += '</td>';
				html += '<td>'+value.NowCase;
				html += '</td>';
				html += '</tr>';
				
				$("#total").append(html);
				
				
				var ctx = document.getElementById('myChart');
				var myChart = new Chart(ctx, {
					type: 'bar',
					data: {
						labels: [value.city1n, value.city2n, value.city3n, value.city4n, value.city5n],
						datasets: [{
							label: '전국 확진자 top5',
							data: [value.city1p, value.city2p, value.city3p, value.city4p, value.city5p],
							backgroundColor: [
								'rgba(255, 99, 132, 0.2)',
								'rgba(54, 162, 235, 0.2)',
								'rgba(255, 206, 86, 0.2)',
								'rgba(75, 192, 192, 0.2)',
								'rgba(153, 102, 255, 0.2)'
							],
							borderColor: [
								'rgba(255, 99, 132, 1)',
								'rgba(54, 162, 235, 1)',
								'rgba(255, 206, 86, 1)',
								'rgba(75, 192, 192, 1)',
								'rgba(153, 102, 255, 1)'
							],
							borderWidth: 1
						}]
					},
					options: {
						responsive: false,
						scales: {
							yAxes: [{
								ticks: {
									beginAtZero: true
								}
							}]
						},
					}
				});
			}
		});
		
	}
	
	
	


	</script>
	

