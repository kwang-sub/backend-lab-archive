<%@ page language="java" contentType="text/html; charset=EUC-KR"
    pageEncoding="EUC-KR"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
    
   <div class="contaner">
	<div class="row">
		<div class="col-3"></div>
		<div class="col-6">
			<form action="/write" method="post">
				<div class="mb-3">
				  <label for="exampleFormControlInput1" class="form-label">ni_no</label>
				  <input disabled name="ni_title" type="text" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com" value="${notice.ni_no }">
				</div>
				<div class="mb-3">
				  <label for="exampleFormControlInput1" class="form-label">title</label>
				  <input disabled name="ni_title" type="text" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com" value="${notice.ni_title }">
				</div>
				
				<div class="mb-3">
				  <label for="exampleFormControlTextarea1" class="form-label">Content</label>
				  <textarea disabled name="ni_content" class="form-control" id="exampleFormControlTextarea1" rows="3" >${notice.ni_content }</textarea>
				</div>
				
			</form>
			
			<c:if test="${loginMember.mi_no eq notice.mi_id}">
				<a class="btn btn-primary" href="/notice/modify?ni_no=${notice.ni_no}">수정</a>
				<a class="btn btn-danger" href="/notice/delete?ni_no=${notice.ni_no }">삭제</a>
			</c:if> 
			
			
		</div>
		<div class="col-3"></div>
	</div>
</div>

