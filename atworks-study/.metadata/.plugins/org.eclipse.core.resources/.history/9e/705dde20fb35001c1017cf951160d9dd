<br><br>
<div class="container">
    <form id="commentListForm" name="commentListForm" method="post">
        <div id="commentList">
        	 <div id ="reset-div">
        	 
        	 <!-- for문 돌릴부분 -->
                   <div>
	                    <table class='table'>
	                   		 <h6><strong>작성자</strong></h6>
	                   		 <tr>
	                   		 	<td>댓글 내용</td>
	                   		 	<td>
	                   		 		<button class="btn btn-primary">수정</button>
	                   		 		<button class="btn btn-danger">삭제</button>
	                   		 	</td>
	                   		 </tr>
	                    </table>
	                </div>
	                <!-- 여기까지 -->
	                
	                
	                
             </div>
        </div>
    </form>
	<div id="pageNav"></div>
</div>


<div class="container">
    <br><br>
        <div>
            <div>
                <span><strong>Comments</strong></span> <span id="cCnt"></span>
            </div>
            <div>
                <table class="table">     
                    <tr>
                        <td>
                            <textarea style="width: 1100px" rows="3" cols="30" id="comment" name="comment" placeholder="댓글을 입력하세요"></textarea>
                            <br>
                            <div>
                                <button id="insert_btn" class="btn pull-right btn-success" onclick="insert()">등록</button>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>
        </div>
</div>





	<script type="text/javascript">
	var ni_no = '${notice.ni_no}';
	var data = {};
	var initialize = function(){
		
		Search(1);
	}
	
	
	function insert() {
		var ri_content = $("#comment").val()
		console.log(ni_no)
		console.log(ri_content)
		/* 여기부터 ajax로 삽입하기! */
		
		$.ajax({
			type : "post",
			url : "/reple/insert",
			data : {
				ni_no : ni_no,
				ri_content : ri_content
			},
			success : function(value) {
				var result = value.result;
				if(result ==1){
					Search(1);
				}
			}
			
		})
		
	}
	
	
	
	var Search = function(selPage) {
		
		
		data.curPage = selPage;
		data.pagePerCnt = 10;
		$.ajax({
			type : 'post',
			url : "/reple/list",
			data : {
				ni_no : ni_no,
				curPage : data.curPage,
				pagePerCnt : data.pagePerCnt
			},
			success : function(value) {
				var reple = value.list;
				$("#reset-div").children().remove();
				var loginMember = "${loginMember.mi_id}"
				var html = "";
				for(var i = 0; i < reple.length; i++){
					html += '<div id ="reple'+i+'">';
					html += '<table class="table">';
					html += '<h6><strong>'+reple[i].mi_id+'</strong></h6>';
					html += '<tr>';
					html += '<td>'+reple[i].ri_content+'</td>';
					html += '<td>';
					if(loginMember == reple[i].mi_id){
						html += '<button type="button" class="btn btn-primary" onclick=modifi('+reple[i].ri_no+',reple'+i+')>수정</button>';
						html += '<button type="button" class="btn btn-danger" onclick=delect('+reple[i].ri_no+')>삭제</button>';
					}
					html += '</td>';
					html += '</tr>';
					html += '</table>';
					html += '</div> ';
				}			
				
				
				$("#reset-div").append(html);
				$("#pageNav").paging({
					pageSize : data.pagePerCnt,  
					PAGE_PER_CNT:  data.pagePerCnt, 
					currentPage: data.curPage,
					pageTotal: value.total
				}); 
			}
		});

	}
	var goPage = function(selPage){
		Search(selPage);
	}
	
	function modifi(ri_no, i) {
		console.log(ri_no);
		console.log(i.id);
		var id = i.id;
		
		$('#'+id+'').children().remove();
		var loginMember = "${loginMember.mi_id}"
		var html = "";
		
			html += '<div id ="'+id+'">';
			html += '<table class="table">';
			html += '<h6><strong>'+loginMember+'</strong></h6>';
			html += '<tr>';
			html += '<td>'+reple[i].ri_content+'</td>';
			html += '<td>';
			if(loginMember == reple[i].mi_id){
				html += '<button type="button" class="btn btn-primary" onclick=realModifi('+ri_no+')>수정</button>';
				html += '<button type="button" class="btn btn-danger" onclick=Search(1)>취소</button>';
			}
			html += '</td>';
			html += '</tr>';
			html += '</table>';
			html += '</div> ';

		
		$('#'+id+'').append(html);
		
		
		
	}
	</script>











 