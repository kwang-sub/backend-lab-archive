package com.spring.shop.reple;

import java.util.List;

import javax.servlet.http.HttpServletRequest;

import org.apache.ibatis.session.SqlSession;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

@Service
public class RepleDAO {

	@Autowired
	SqlSession ss;
	
	public void getList(HttpServletRequest req) {
		// TODO Auto-generated method stub
		int ni_no = Integer.parseInt(req.getParameter("ni_no"));
		System.out.println(ni_no);
		List<RepleVO> rList = ss.getMapper(RepleMapper.class).getList(ni_no);
		
		for(RepleVO v : rList) {
			System.out.println(v);
		}
		
	}

}
